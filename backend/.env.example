# Supabase Configuration
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Server Configuration
PORT=3000
NODE_ENV=development

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_change_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# API Configuration
API_VERSION=v1
API_PREFIX=/api
FRONTEND_URL=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
LOG_FILE=logs/app.log

# Email Configuration (for notifications)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASS=your_email_password

# SMS Configuration (for OTP)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# WebSocket Configuration
WEBSOCKET_PORT=3001

# Cors Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:19006

# Feature Flags
ENABLE_REAL_TIME=true
ENABLE_NOTIFICATIONS=true
ENABLE_SMS=false

# TTLock Cloud Configuration
TTLOCK_CLIENT_ID=your_ttlock_cloud_client_id
TTLOCK_CLIENT_SECRET=your_ttlock_cloud_client_secret
TTLOCK_API_BASE_URL=https://api.sciener.com

# CRITICAL: TTLock Token Encryption Key
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# MUST be exactly 64 hexadecimal characters
# NEVER change this after deployment (invalidates all user tokens!)
# Store securely in production (AWS Secrets Manager, Azure Key Vault, etc.)
TTLOCK_ENCRYPTION_KEY=generate_64_char_hex_key_using_command_above

# OpenAI Configuration (Required for AI Features)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=1000
OPENAI_TEMPERATURE=0.7

# AI Feature Configuration
AI_CACHE_TTL_SECONDS=3600
AI_SUMMARY_CACHE_TTL_SECONDS=86400
