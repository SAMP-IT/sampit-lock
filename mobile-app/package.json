{
  "name": "awakey-smart-lock-mobile",
  "version": "1.0.0",
  "description": "AwayKey Smart Lock Mobile Application",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "clear": "expo start --clear",
    "prebuild": "expo prebuild",
    "prebuild:clean": "expo prebuild --clean",
    "build:android": "expo run:android --variant release",
    "build:debug-apk": "expo prebuild --platform android --clean",
    "build:debug-apk:gradle": "cd android && gradlew.bat assembleDebug && cd ..",
    "build:debug-apk:full": "npm run build:debug-apk && npm run build:debug-apk:gradle",
    "install:all": "npm install && cd android && ./gradlew clean && cd .."
  },
  "keywords": [
    "smart-lock",
    "react-native",
    "expo",
    "bluetooth",
    "ttlock"
  ],
  "author": "Awakey Team",
  "license": "MIT",
  "dependencies": {
    "@expo/vector-icons": "^14.0.0",
    "@react-native-async-storage/async-storage": "^1.23.1",
    "@react-native-community/datetimepicker": "^7.6.1",
    "@react-native-community/slider": "^4.5.2",
    "@react-navigation/bottom-tabs": "^6.5.20",
    "@react-navigation/native": "^6.1.17",
    "@react-navigation/stack": "^6.3.29",
    "@sentry/react-native": "^7.8.0",
    "@supabase/supabase-js": "^2.39.3",
    "axios": "^1.6.7",
    "expo": "^51.0.0",
    "expo-clipboard": "~6.0.3",
    "expo-constants": "~16.0.1",
    "expo-device": "~6.0.2",
    "expo-font": "~12.0.5",
    "expo-linear-gradient": "~13.0.2",
    "expo-modules-core": "~1.12.26",
    "expo-notifications": "^0.28.19",
    "expo-sharing": "~12.0.1",
    "expo-status-bar": "~1.12.1",
    "lottie-react-native": "^7.3.5",
    "md5": "^2.3.0",
    "react": "18.2.0",
    "react-native": "0.74.1",
    "react-native-dotenv": "^3.4.11",
    "react-native-gesture-handler": "~2.16.1",
    "react-native-reanimated": "~3.10.1",
    "react-native-safe-area-context": "4.10.1",
    "react-native-screens": "3.31.1",
    "react-native-ttlock": "^2.2.6"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "babel-preset-expo": "~11.0.0",
    "expo-build-properties": "^1.0.9",
    "expo-modules-autolinking": "^1.11.3"
  },
  "private": true
}
